{
  "name": "maxifai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=development concurrently \"npm run start-backend\" \"npm run dev\" \"npm run start-electron\"",
    "start-backend": "cd ../backend && python start_api.py",
    "start-electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build-all": "node electron/build.cjs",
    "build:backend": "cd ../backend && pyinstaller AIMaxiFAI.spec --noconfirm",
    "build:frontend": "npm run build",
    "electron:build:win": "electron-builder --win --x64",
    "clean": "rimraf dist releases build backend",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.6",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.10.1",
    "electron-squirrel-startup": "^1.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.2",
    "rimraf": "^5.0.0",
    "fs-extra": "^11.2.0"
  },
  "build": {
    "appId": "com.aimaxifai.app",
    "productName": "AI MaxiFAI",
    "directories": {
      "output": "releases",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "./backend",
        "filter": [
          "**/*",
          "!**/*.pyc",
          "!**/__pycache__",
          "!**/*.log",
          "!**/build/**",
          "!**/dist/**"
        ]
      },
      {
        "from": "dist",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "highestAvailable"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "differentialPackage": false,
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "unicode": true,
      "runAfterFinish": true
    }
  }
}
