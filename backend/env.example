# AI Trainer API Environment Variables

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# File Upload Settings
MAX_FILE_SIZE=100  # MB
UPLOAD_DIR=./uploads
OUTPUT_DIR=./assets/output

# Analysis Settings
MAX_CONCURRENT_ANALYSES=3
ANALYSIS_TIMEOUT=3600  # seconds

# WebSocket Settings
WEBSOCKET_TIMEOUT=300  # seconds

# Configuration File
CONFIG_PATH=./config.yaml

# Logging
LOG_LEVEL=info

# WebRTC ICE Servers (JSON array)
# Example for production with TURN server:
# ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:your-turn-server.com:3478"],"username":"user","credential":"pass"}]
# Default: Google STUN server
ICE_SERVERS_JSON=["stun:stun.l.google.com:19302"]

# CORS Settings (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Trusted Hosts (comma-separated)
TRUSTED_HOSTS=localhost,127.0.0.1

# Redis (for background tasks)
REDIS_URL=redis://localhost:6379/0

# Database (if needed in future)
# DATABASE_URL=sqlite:///./ai_trainer.db
